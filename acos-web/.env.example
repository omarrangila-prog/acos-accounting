# PostgreSQL connection string.
#
# Local development — point at your own Postgres:
#   DATABASE_URL="postgresql://USER:PASSWORD@localhost:5432/acos_accounting?schema=public"
#
# Railway — add a PostgreSQL plugin to the project, then in this service's
# Variables tab reference the plugin's connection string:
#   DATABASE_URL=${{Postgres.DATABASE_URL}}
# Railway injects it automatically; do NOT hard-code credentials here.
DATABASE_URL="postgresql://USER:PASSWORD@localhost:5432/acos_accounting?schema=public"
