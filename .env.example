# ============================================================
# ACOS Accounting Software — Environment Variables
# Copy this file to .env and fill in real values.
# NEVER commit .env to git.
# ============================================================

# ---- Firebase Admin SDK (server-side Firestore) ----
# Get these from Firebase Console → Project Settings → Service Accounts
FIREBASE_PROJECT_ID="your-firebase-project-id"
FIREBASE_CLIENT_EMAIL="firebase-adminsdk-xxxxx@your-project.iam.gserviceaccount.com"
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"

# ---- PIN Authentication ----
# Bcrypt hashes (cost 12) of the 4-digit PINs.
# Generate with: node -e "const b=require('bcryptjs');console.log(b.hashSync('YOUR_PIN',12))"
# PIN 4444 → opens production (existing client data, flat Firestore collections)
# PIN 5555 → opens demo    (tenants/demo/ sub-collections, fake data)
PIN_HASH_PRODUCTION="$2b$12$..."
PIN_HASH_DEMO="$2b$12$..."

# ---- Session Security ----
# Long random string used to HMAC-sign the session cookie.
# Generate: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
SESSION_SECRET="change-this-to-a-long-random-string-in-production"
